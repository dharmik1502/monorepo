# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                   MONOREPO ENVIRONMENT VARIABLES                           ║
# ║  Copy this file to apps/frontend/.env.local and apps/backend/.env          ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ──────────────────────────────────────────────────────────────────────────────
# FRONTEND (apps/frontend/.env.local)
# ──────────────────────────────────────────────────────────────────────────────

# RapidAPI key — used by the Next.js server-side download route
# Sign up at https://rapidapi.com (free tier available)
# Subscribe to: social-media-video-downloader, instagram-downloader-download-instagram-videos-stories4,
#               facebook-video-downloader4, tiktok-video-no-watermark2, youtube-media-downloader
RAPIDAPI_KEY=your-rapidapi-key-here

# URL of the NestJS backend (used by the frontend proxy route)
# In development: http://localhost:4000
# In production: your deployed backend URL
BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# ──────────────────────────────────────────────────────────────────────────────
# BACKEND (apps/backend/.env)
# ──────────────────────────────────────────────────────────────────────────────

# Server
PORT=4000
NODE_ENV=development

# Supabase project credentials
# Get from: https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Database URL (used for direct Postgres connections if needed)
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Rate limiting (requests per TTL window per IP)
THROTTLE_TTL=60
THROTTLE_LIMIT=30

# Cache TTL in seconds (how long download results are cached)
CACHE_TTL=300

# App secret (used for signing tokens, etc.)
APP_SECRET=your-very-long-random-secret-key-here

# Comma-separated list of allowed CORS origins
# Add your production frontend domain here
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ScrapeCreators API key (optional — for enhanced scraping)
SCRAPE_CREATORS_API_KEY=DjNUud0o2nN8M3fzFXteSekUXEU2
